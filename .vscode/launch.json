// A launch configuration that compiles then opens the extension in a new VSCode window.
// Press F5 in the extension folder to start debugging.
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: compile",
      "sourceMaps": true
    }
  ]
}
